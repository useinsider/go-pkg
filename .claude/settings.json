{
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "context7@aio-plugin-marketplace": true,
    "engineering-knowledge-base@aio-plugin-marketplace": true,
    "safety@aio-plugin-marketplace": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-env-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/gofmt-on-write.sh"
          }
        ]
      }
    ]
  }
}
